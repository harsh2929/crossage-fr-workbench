{
  "mcpServers": {
    "vintrace": {
      "type": "stdio",
      "command": "/absolute/path/to/face/.venv/bin/python",
      "args": [
        "-m",
        "crossage_fr.mcp_server",
        "--workspace",
        "/absolute/path/to/vintrace-workspace"
      ],
      "env": {
        "PYTHONPATH": "/absolute/path/to/face",
        "VINTRACE_WORKSPACE": "/absolute/path/to/vintrace-workspace",
        "CROSSAGE_WORKSPACE": "/absolute/path/to/vintrace-workspace"
      }
    }
  }
}
