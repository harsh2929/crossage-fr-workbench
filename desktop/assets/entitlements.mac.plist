<?xml version="1.0" encoding="UTF-8"?>
<!--
  BRS-3: entitlements for a hardened-runtime, notarized macOS build.
  These only take effect when the app is code-signed (CSC_IDENTITY_AUTO_DISCOVERY
  is not "false" and a Developer ID identity is available); the current unsigned
  build skips signing, so this file is inert until signing is enabled.

  - allow-jit / allow-unsigned-executable-memory: required by Electron's V8.
  - disable-library-validation: required because the app bundles a PyInstaller-
    frozen Python backend with native libraries (onnxruntime, OpenCV, faiss)
    that are not signed by the same Developer ID identity.
  - device.camera: the workbench can capture local review photos.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.device.camera</key>
    <true/>
  </dict>
</plist>
