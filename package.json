{
  "name": "vintrace",
  "version": "0.1.0",
  "description": "Local face and photo review workbench",
  "author": "Vintrace",
  "license": "UNLICENSED",
  "main": "desktop/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node desktop/scripts/run-electron.cjs .",
    "start": "npm-run-all --parallel dev electron:dev",
    "desktop": "npm run build && node desktop/scripts/run-electron.cjs .",
    "build": "tsc --noEmit && vite build",
    "backend:check": ".venv/bin/python -m crossage_fr.api_server < /dev/null",
    "mcp": "node desktop/scripts/run-mcp.cjs",
    "mcp:http": "node desktop/scripts/run-mcp.cjs --transport streamable-http",
    "mcp:bundle": "npm run build:backend && node desktop/scripts/build-mcp-bundle.cjs",
    "build:backend": "node desktop/scripts/build-backend.cjs",
    "pack": "npm run build && npm run build:backend && electron-builder --dir",
    "pack:unsigned": "npm run build && npm run build:backend && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist:mac": "node desktop/scripts/require-platform.cjs darwin && npm run build && npm run build:backend && electron-builder --mac dmg zip --publish never",
    "dist:mac:unsigned": "node desktop/scripts/require-platform.cjs darwin && npm run build && npm run build:backend && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never",
    "dist:win": "node desktop/scripts/require-platform.cjs win32 && npm run build && npm run build:backend && electron-builder --win nsis --publish never",
    "dist:all": "npm run dist:mac && npm run dist:win",
    "test:pipeline": "PYTHONPATH=. CROSSAGE_FORCE_FALLBACK=1 .venv/bin/python tests/pipeline_smoke.py",
    "test:edge": "PYTHONPATH=. CROSSAGE_FORCE_FALLBACK=1 .venv/bin/python tests/edge_cases.py",
    "test:age-gap": "PYTHONPATH=. .venv/bin/python tests/age_gap_units.py",
    "test:quality": "PYTHONPATH=. .venv/bin/python tests/quality_units.py",
    "test:detection": "PYTHONPATH=. .venv/bin/python tests/detection_units.py",
    "test:calibration": "PYTHONPATH=. CROSSAGE_FORCE_FALLBACK=1 .venv/bin/python tests/calibration_units.py",
    "test:benchmark-units": "PYTHONPATH=. .venv/bin/python tests/benchmark_units.py",
    "test:det-eval": "PYTHONPATH=. .venv/bin/python tests/det_eval_units.py",
    "test:clustering": "PYTHONPATH=. .venv/bin/python tests/clustering_units.py",
    "test:fiqa": "PYTHONPATH=. .venv/bin/python tests/fiqa_units.py",
    "test:mcp": ".venv/bin/python tests/mcp_smoke.py",
    "test:filesystem-chaos": "node desktop/scripts/run-python.cjs tests/filesystem_chaos.py",
    "test:backup-roundtrip": "node desktop/scripts/run-python.cjs tests/workspace_backup_roundtrip.py",
    "test:dataset-benchmark": "node desktop/scripts/run-python.cjs tests/public_dataset_benchmark.py",
    "test:dataset-gates": "node desktop/scripts/run-python.cjs tests/dataset_regression_gates.py",
    "test:e2e": "playwright test",
    "test:clean": "node desktop/scripts/run-python.cjs tests/clean_workspace_smoke.py",
    "bench:scale": "PYTHONPATH=. CROSSAGE_FORCE_FALLBACK=1 .venv/bin/python tests/scale_benchmark.py",
    "bench:accuracy": "PYTHONPATH=. CROSSAGE_FORCE_FALLBACK=1 .venv/bin/python tests/accuracy_benchmark.py",
    "update:dry-run": "node desktop/scripts/check-update-feed.cjs",
    "package:check": "node desktop/scripts/check-package-artifacts.cjs",
    "release:artifacts": "node desktop/scripts/create-release-artifacts.cjs",
    "release:verify": "node desktop/scripts/verify-release-assets.cjs",
    "release:check": "node desktop/scripts/run-python.cjs tests/release_check.py",
    "test:model-downloader": "node desktop/scripts/run-python.cjs tests/model_downloader_failures.py",
    "test:safety-model": "node desktop/scripts/run-python.cjs tests/safety_model_inference.py",
    "test:perf-budget": "node desktop/scripts/run-python.cjs tests/performance_budget.py",
    "test:localization": "node desktop/scripts/check-localization.cjs",
    "test:main-util": "node tests/main_util.test.cjs",
    "test:crypto": "PYTHONPATH=. .venv/bin/python tests/crypto_roundtrip.py",
    "test:command-contract": "node desktop/scripts/run-python.cjs tests/command_contract.py",
    "test:e2e:buttons": "cross-env VINTRACE_BUTTON_AUDIT=1 playwright test tests/e2e/button-regression.spec.ts",
    "test:e2e:i18n": "cross-env VINTRACE_I18N_LAYOUT=1 playwright test tests/e2e/localization-layout.spec.ts",
    "test:e2e:ipc": "cross-env VINTRACE_IPC_FUZZ=1 playwright test tests/e2e/ipc-security.spec.ts",
    "test:e2e:a11y": "cross-env VINTRACE_A11Y=1 playwright test tests/e2e/accessibility-keyboard.spec.ts",
    "test:e2e:packaged": "cross-env VINTRACE_PACKAGED_SMOKE=1 playwright test tests/e2e/packaged.spec.ts",
    "test:e2e:soak": "cross-env VINTRACE_SOAK=1 playwright test tests/e2e/memory-soak.spec.ts",
    "test": "npm run build && npm run test:localization && npm run test:main-util && npm run test:pipeline && npm run test:age-gap && npm run test:quality && npm run test:detection && npm run test:calibration && npm run test:benchmark-units && npm run test:det-eval && npm run test:clustering && npm run test:fiqa && npm run test:edge && npm run test:filesystem-chaos && npm run test:backup-roundtrip && npm run test:dataset-benchmark && npm run test:dataset-gates && npm run test:model-downloader && npm run test:mcp && npm run test:perf-budget && npm run test:e2e"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^10.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.vintrace.workbench",
    "productName": "Vintrace",
    "publish": [
      {
        "provider": "github",
        "owner": "harsh2929",
        "repo": "crossage-fr-workbench"
      }
    ],
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Vintrace Link",
        "schemes": [
          "vintrace"
        ]
      }
    ],
    "fileAssociations": [
      {
        "name": "Image files",
        "ext": [
          "jpg",
          "jpeg",
          "jpe",
          "jfif",
          "png",
          "apng",
          "gif",
          "webp",
          "avif",
          "heic",
          "heif",
          "hif",
          "heics",
          "heifs",
          "bmp",
          "dib",
          "tif",
          "tiff",
          "ico",
          "icns",
          "jp2",
          "j2k",
          "jpc",
          "jpf",
          "jpx",
          "ppm",
          "pgm",
          "pbm",
          "pnm",
          "tga",
          "dds",
          "psd",
          "dng",
          "raw",
          "arw",
          "cr2",
          "cr3",
          "nef",
          "nrw",
          "orf",
          "raf",
          "rw2",
          "pef",
          "srw",
          "x3f",
          "3fr",
          "erf",
          "kdc",
          "mos",
          "mrw"
        ],
        "role": "Viewer"
      },
      {
        "name": "Video files",
        "ext": [
          "mov",
          "mp4",
          "m4v",
          "avi",
          "mkv",
          "webm",
          "hevc",
          "3gp",
          "3g2",
          "mts",
          "m2ts",
          "qt",
          "mpeg",
          "mpg",
          "wmv",
          "flv",
          "asf",
          "ogv",
          "dv"
        ],
        "role": "Viewer"
      }
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend",
        "filter": [
          "crossage-backend",
          "crossage-backend.exe",
          "crossage-backend/**/*"
        ]
      },
      {
        "from": "crossage_fr",
        "to": "crossage_fr",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "requirements-production.txt",
        "to": "requirements-production.txt"
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "mcp",
        "to": "mcp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "models/safety",
        "to": "models/safety",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "models/insightface",
        "to": "models/insightface",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "report.md",
        "to": "report.md"
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "icon": "desktop/assets/icon.icns",
      "extendInfo": {
        "NSCameraUsageDescription": "Vintrace uses the camera to capture local review photos for face matching."
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "desktop/assets/entitlements.mac.plist",
      "entitlementsInherit": "desktop/assets/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "desktop/assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
